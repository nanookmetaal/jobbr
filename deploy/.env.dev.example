# Copy this to .env at the repo root on your Proxmox LXC
# DATABASE_URL is overridden by docker-compose.yml to point at the db service

DATABASE_URL=postgresql+asyncpg://jobbr:jobbr@db:5432/jobbr

ANTHROPIC_API_KEY=your_anthropic_key
VOYAGE_API_KEY=your_voyage_key
RESEND_API_KEY=your_resend_key

# Use a dev sender address - can be the same domain with a different prefix
EMAIL_FROM=Jobbr Dev <dev@yourdomain.com>

# These should match your Cloudflare Tunnel hostnames
FRONTEND_URL=https://dev.yourdomain.com

# Generate with: openssl rand -hex 32
JWT_SECRET=generate_a_secret_here

# Generate with: openssl rand -hex 32 — must match SERVICE_KEY in frontend env
SERVICE_KEY=generate_a_secret_here

# The email that receives access request notifications
ADMIN_EMAIL=your@email.com
